# Copie para .env e preencha. O .env NUNCA vai para o Git (§7.1 — vazar segredo = nota zero no deploy).
#
# Chave da YouTube Data API v3 (só necessária quando modo_demo: false).
# Obtenha em https://console.cloud.google.com/ > APIs & Services > Credentials.
YOUTUBE_API_KEY=

# Caminho do lakehouse (opcional; padrão ./datalake). Útil para apontar o dashboard
# ao mesmo lakehouse do ingestor quando rodam em diretórios diferentes.
# DATALAKE_DIR=./datalake
